{
  "expo": {
    "name": "Fragmentos de Alma",
    "slug": "fragmentos-de-alma",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "fragmentos-de-alma",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fragmentosde.alma",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Câmera não utilizada neste aplicativo.",
        "NSPhotoLibraryUsageDescription": "Acesso à galeria não utilizado neste aplicativo."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "package": "com.fragmentosde.alma",
      "versionCode": 1,
      "predictiveBackGestureEnabled": false,
      "permissions": []
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "00678b1a-b8d5-4e27-9436-ceda357ab890"
      }
    },
    "owner": "martinsluan"
  }
}
